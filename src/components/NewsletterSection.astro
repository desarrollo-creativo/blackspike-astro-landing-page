---
import Image from "astro/components/Image.astro"
import bg_image from "../assets/theme-images/hero-image.png"

const { newsletter } = Astro.props

const evolutionDomain = import.meta.env.PUBLIC_EVOLUTION_DOMAIN;
const evolutionInstance = import.meta.env.PUBLIC_EVOLUTION_INSTANCE;
const evolutionToken = import.meta.env.PUBLIC_EVOLUTION_TOKEN;

---

<aside class="@container bs-container bs-mt-lg text-center" id="newsletter">

  <!-- Wrapper -->
  <div class="p-6 md:py-16 relative rounded-xl overflow-hidden flex justify-center isolate w-full h-full border border-dc-purple/20"
    style="background: linear-gradient(135deg, rgba(14,165,233,0.08) 0%, rgba(124,58,237,0.12) 100%)">

    <!-- BG image -->
    <Image src={ bg_image } alt="" format="avif" height={1080} width={1920} class="rounded-xl overflow-hidden w-full h-full object-cover object-left absolute inset-0 opacity-20" />

    <!-- Glow orb -->
    <div class="pointer-events-none absolute -top-20 left-1/2 -translate-x-1/2 w-96 h-48 rounded-full opacity-30 blur-[80px]"
      style="background: radial-gradient(ellipse, #7C3AED, transparent 70%)"></div>

    <!-- Content -->
    <div class="z-10 p-6 md:p-10 lg:p-20 rounded-xl md:max-w-lg flex flex-col gap-6 bg-bs-surface-0/90 h-full border border-dc-blue/15"
      style="box-shadow: 0 0 40px rgba(124,58,237,0.1)">

      <!-- Title -->
      <h2 class="bs-h2" set:html={ newsletter.title } />

      <!-- Intro -->
      <div class="bs-body-text flex-grow" set:html={ newsletter.content } />

      <!-- Form -->
      <form id="newsletter-form" class="flex gap-4 flex-col">

        <label class="sr-only" for="nl-name">Tu nombre</label>
        <input
          id="nl-name"
          name="name"
          class="border-2 rounded-lg bg-bs-surface-0 border-bs-surface-3 form-input px-4 py-3"
          placeholder="Jhon Doe">

        <label class="sr-only" for="nl-phone">Tu número de celular</label>
        <input
          id="nl-phone"
          name="phone"
          type="tel"
          class="border-2 rounded-lg bg-bs-surface-0 border-bs-surface-3 form-input px-4 py-3"
          placeholder="69405752">

        <input id="newsletter-submit" type="submit" value={ newsletter.cta } class="bs-btn form-input px-4 py-3">

      </form>

    </div>

  </div>

  <!-- Toast Notification -->
  <div id="toast-notification" class="fixed bottom-5 right-5 z-50 px-4 py-3 rounded-lg text-white bg-green-500 transition-all duration-300 opacity-0 translate-y-4 pointer-events-none">
    <span id="toast-message"></span>
  </div>

</aside>

<script define:vars={{ evolutionDomain, evolutionInstance, evolutionToken }} is:inline>
  const form = document.getElementById('newsletter-form');
  const submitButton = document.getElementById('newsletter-submit');
  const toast = document.getElementById('toast-notification');
  const toastMessage = document.getElementById('toast-message');
  let toastTimeout;

  // --- Form Submission Logic ---
  form.addEventListener('submit', async (event) => {
    event.preventDefault();

    const originalButtonText = submitButton.value;
    submitButton.value = 'Enviando...';
    submitButton.disabled = true;

    const formData = new FormData(form);
    const name = formData.get('name')?.trim();
    const phone = formData.get('phone')?.trim();

    // Validations
    if (name.length <= 2) {
      showToast('Tu nombre debe tener más de 2 caracteres.', true);
      submitButton.value = originalButtonText;
      submitButton.disabled = false;
      return;
    }
    if (!/^\d{8}$/.test(phone)) {
      showToast('Tu número de celular debe tener 8 dígitos.', true);
      submitButton.value = originalButtonText;
      submitButton.disabled = false;
      return;
    }

    const evolutionUrl = `${evolutionDomain}/message/sendText/${evolutionInstance}`;
    const evolutionHeaders = { 'Content-Type': 'application/json', 'apikey': evolutionToken };
    const text = `la persona *${name}* con el numero de celular *${phone}* quiere recibir novedades sobre la empresa`;

    try {
      const response = await fetch(evolutionUrl, {
        method: 'POST',
        headers: evolutionHeaders,
        body: JSON.stringify({ number: '59175199157', text }),
      });

      if (response.ok) {
        showToast('¡Gracias por suscribirte! Pronto recibirás novedades.');

        const welcomeMessage = `¡Hola, *${name}*! 👋 ¡Bienvenido/a a la comunidad de *Desarrollo Creativo*! 🚀 A partir de ahora, recibirás nuestras últimas novedades y ofertas especiales. ¡Gracias por unirte! ✨`;
        await fetch(evolutionUrl, {
          method: 'POST',
          headers: evolutionHeaders,
          body: JSON.stringify({ number: `591${phone}`, text: welcomeMessage }),
        });

        form.reset();
      } else {
        showToast('Hubo un error al enviar tu solicitud. Por favor, inténtalo de nuevo.', true);
      }
    } catch (error) {
      showToast('Hubo un error de red. Por favor, revisa tu conexión e inténtalo de nuevo.', true);
    } finally {
      submitButton.value = originalButtonText;
      submitButton.disabled = false;
    }
  });

  // --- Toast Notification Logic ---
  function showToast(message, isError = false) {
    clearTimeout(toastTimeout);

    toastMessage.textContent = message;

    // Set color based on success or error
    toast.classList.toggle('bg-red-500', isError);
    toast.classList.toggle('bg-green-500', !isError);

    // Show toast
    toast.classList.remove('opacity-0', 'translate-y-4');
    toast.classList.add('opacity-100', 'translate-y-0');

    // Hide toast after 3 seconds
    toastTimeout = window.setTimeout(() => {
      toast.classList.remove('opacity-100', 'translate-y-0');
      toast.classList.add('opacity-0', 'translate-y-4');
    }, 3000);
  }
</script>
