---

import Logo from '../assets/theme-images/logo.svg'

const { settings } = Astro.props

---

<header class="wrapper font-semibold sticky top-0 z-40 backdrop-blur-md bg-bs-surface-0/80 border-b border-dc-blue/10">

  <!-- Wrapper -->
  <div class="bs-container py-4 flex justify-between items-center">

    <!-- Logo -->
    <a class="flex xl:min-w-32 group" href="/" aria-label={ settings.title + ' - Inicio' }>

      <Logo height="48" width="48" />

    </a>

    <!-- Nav -->
    <nav class="hidden col-span-6 md:flex mx-auto self-stretch lg:gap-2">

      <!-- Links -->
      { settings.nav.map( item =>

        <a class="bs-btn !bg-transparent before:translate-y-full hover:before:translate-y-0" href={item.link}>
          { item.title }
        </a>

      )}

    </nav>

    <!-- CTA -->
    <button type="button" class="min-w-32 bs-btn" onclick="demo.showModal()">

      { settings.demo.title }

    </button>

  </div>

</header>
