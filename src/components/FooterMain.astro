---

import Logo from '../assets/theme-images/logo.svg'

const { settings } = Astro.props

---

<footer class="@container bs-container my-24 font-semibold text-bs-foreground-dark [&_a]:hover:text-bs-foreground-light [&_a]:transition-color [&_a]:duration-150" id="contact">

  <!-- Wrapper -->
  <div class="p-6 md:p-16 rounded-xl grid md:grid-cols-2 gap-8 border border-dc-blue/15 relative overflow-hidden"
    style="background: linear-gradient(135deg, rgba(14,165,233,0.05) 0%, rgba(124,58,237,0.08) 100%)">

    <!-- Footer glow -->
    <div class="pointer-events-none absolute -bottom-16 -right-16 w-64 h-64 rounded-full opacity-20 blur-[80px]"
      style="background: radial-gradient(circle, #7C3AED, transparent 70%)"></div>

      <!-- Left col -->
      <div class="w-max flex flex-col gap-8 md:gap-0 justify-between text-bs-foreground-light">

        <!-- Logo -->
        <a class="flex group" href="#top" aria-label="Back to top">

          <Logo class="group-hover:scale-80 transition-transform ease-bs-spring duration-1000" height="48" width="48" />

        </a>

        <!-- CTA title -->
        <h2 class="bs-h3">{ settings.demo.title  }</h2>

        <!-- CTA Button -->
        <button type="button" class="min-w-32 bs-btn block" onclick="demo.showModal()">
          { settings.demo.cta }
        </button>

      </div>

      <!-- Right col -->
      <div class="flex gap-10 md:gap-2 lg:gap-20 md:justify-end [&_a]:block md:[&_a]:px-5 [&_a]:py-2">

        <!-- Nav -->
        <nav class="flex flex-col">

          { settings.nav.sort((a,b) => a.title.localeCompare(b.title)).map( item =>

            <a href={ item.link }>
              { item.title }
            </a>

          )}

        </nav>

        <!-- Social links -->
        <nav class="flex flex-col">

          { settings.social_links.sort((a,b) => a.title.localeCompare(b.title)).map( item =>

            <a href={ item.link } target="_blank">
              { item.title }
            </a>

          )}

        </nav>

      </div>

  </div>


  <!-- Colophon -->
  <aside class="bs-container">

      <nav class="flex gap-4 justify-center pt-16 md:pt-24 text-xs">

        <!-- Copyright/Date -->
        <a href="https://blackspike.com/" target="_blank">Template by blackspike.com</a>

        <!-- Credits -->
        <a href="/credits" target="_blank">Credits</a>

      </nav>

  </aside>

</footer>

