---

import Image from "astro/components/Image.astro"
import hero_screens from "../assets/theme-images/hero-screens.png"

const { settings, title, content } = Astro.props

---

<section class="bs-container py-6 flex flex-col lg:flex-row items-center relative overflow-hidden">

  <!-- Ambient glow orbs -->
  <div class="pointer-events-none absolute -top-32 -left-32 w-[480px] h-[480px] rounded-full opacity-30 blur-[120px]"
    style="background: radial-gradient(circle, #0EA5E9, transparent 70%)"></div>
  <div class="pointer-events-none absolute top-10 right-0 w-80 h-80 rounded-full opacity-20 blur-[100px]"
    style="background: radial-gradient(circle, #7C3AED, transparent 70%)"></div>
  <div class="pointer-events-none absolute bottom-0 left-1/3 w-64 h-64 rounded-full opacity-15 blur-[80px]"
    style="background: radial-gradient(circle, #F97316, transparent 70%)"></div>

  <!-- Content -->
  <div class="flex flex-col gap-6 lg:max-w-lg w-full py-16 relative z-10">

    <!-- Title -->
    <h1 class="bs-h1" set:html={ title } />

    <!-- Content -->
    <div class="bs-body-text xl:text-xl flex flex-col gap-4 [&_p]:last:text-bs-foreground-dark" set:html={ content } />

    <!-- CTA -->
    <button type="button" class="bs-btn self-start bs-mt-sm" onclick="demo.showModal()">
      { settings.demo.cta }
    </button>

  </div>

  <!-- Image -->
  <figure class="flex justify-end flex-1 -mt-20 lg:mt-0 relative z-10 lg:pl-8 group">

    <Image
      src={ hero_screens }
      format="avif"
      quality="high"
      alt="Screens showing phone, tablet and desktop views of our website"
      loading="eager"
      class="w-full max-w-2xl lg:max-w-none transition-transform duration-500 ease-out group-hover:scale-105 group-hover:-translate-y-2 group-hover:drop-shadow-[0_24px_48px_rgba(14,165,233,0.25)]"
    />

  </figure>

</section>
